# Required — pick ONE auth method below (Vertex takes precedence if both are set)

# Option A: direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Google Cloud Vertex AI (use if direct Anthropic billing isn't available)
# CLAUDE_CODE_USE_VERTEX=1
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=global
# GOOGLE_APPLICATION_CREDENTIALS_JSON=<base64-encoded service-account key JSON>

RUNNER_SHARED_SECRET=change-me-to-a-long-random-string

# Optional (defaults shown)
PORT=8080
MAX_CONCURRENT_JOBS=1
MAX_TURNS=80
MAX_BUDGET_USD=5
CLAUDE_MODEL=
