{
  "name": "agent-runner",
  "version": "0.2.0",
  "description": "HTTP service that turns a YouTube URL into a Korean .pptx deck: yt-dlp extraction -> OpenAI structured outline -> deterministic pptxgenjs template rendering.",
  "private": true,
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "openai": "^6.48.0",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "sharp": "^0.35.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
